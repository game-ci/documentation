{
  // This file is not used in compilation. It is here just for a nice editor experience.
  "extends": "@docusaurus/tsconfig/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "module": "esnext",
    "target": "es2022",
    "types": ["node", "vitest/globals"]
  },
  "exclude": [
    "**/node_modules/**",
    "**/build/**",
    "**/.docusaurus/**",
    "e2e/**",
    "vitest.config.mts"
  ]
}
