{
  "name": "game-ci",
  "version": "0.0.0",
  "description": "Website for projects within the GameCI group",
  "private": true,
  "engines": {
    "npm": "please-use-yarn",
    "yarn": ">= 4.0.0",
    "node": ">= 20.x"
  },
  "scripts": {
    "prepare": "husky",
    "docusaurus": "docusaurus",
    "dev": "node scripts/ensure-husky.mjs && yarn start",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "test": "node scripts/ensure-husky.mjs && vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "lint": "yarn oxlint --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "typecheck:tsgo": "tsgo --noEmit",
    "setup:hooks": "node scripts/ensure-husky.mjs"
  },
  "lint-staged": {
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs)": [
      "oxlint --fix --quiet",
      "oxfmt --write"
    ],
    "*.@(json|jsonc|json5|md|mdx|yaml|yml|css|scss|sass|html|toml)": "oxfmt --write",
    ".github/workflows/*.@(yml|yaml)": "actionlint"
  },
  "dependencies": {
    "@docusaurus/core": "^2.4.1",
    "@docusaurus/module-type-aliases": "^2.4.1",
    "@docusaurus/preset-classic": "^2.4.1",
    "@docusaurus/theme-common": "^2.4.1",
    "@docusaurus/theme-mermaid": "2.4.1",
    "@docusaurus/tsconfig": "^3.0.0-alpha.0",
    "@mdx-js/react": "^1.6.22",
    "@reduxjs/toolkit": "^1.8.1",
    "antd": "^4.20.2",
    "autoprefixer": "^10.4.12",
    "classnames": "^2.3.2",
    "clsx": "^1.1.1",
    "docusaurus-gtm-plugin": "^0.0.2",
    "docusaurus-plugin-sass": "^0.2.5",
    "firebase": "^8.2.9",
    "postcss": "^8.4.18",
    "prism-react-renderer": "^1.3.1",
    "prop-types": "^15.8.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-hot-toast": "^2.2.0",
    "react-icons": "^4.10.1",
    "react-instantsearch-dom": "^6.24.0",
    "react-player": "^2.10.0",
    "react-redux": "^8.0.1",
    "react-spinners": "^0.11.0",
    "react-spring": "^9.4.5",
    "react-table": "^7.7.0",
    "react-visibility-sensor": "^5.1.1",
    "reactfire": "^3.0.0-rc.0",
    "redux": "^4.2.0",
    "sass": "^1.51.0",
    "tailwindcss": "^3.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^12",
    "@typescript/native-preview": "^7.0.0-dev.20260505.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^3",
    "concurrently": "^7.2.1",
    "eslint": "^10.3.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-flowtype": "^5.2.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "happy-dom": "^20.9.0",
    "husky": "9",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsc-files": "^1.1.3",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3"
  },
  "resolutions": {
    "uuid@npm:^11.1.0": "14.0.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@4.14.1",
  "dependenciesMeta": {
    "core-js": {
      "built": true
    },
    "core-js-pure": {
      "built": true
    },
    "lefthook": {
      "built": true
    },
    "protobufjs": {
      "built": true
    }
  }
}
